#!/usr/bin/env bash
# ports — list active local dev servers (node/bun/next/deno/vite listeners).
# Columns: PORT  PID  UPTIME  PROJECT (cwd, ~-shortened)
set -u

printf '%-6s %-7s %-9s %s\n' PORT PID UPTIME PROJECT

lsof -nP -iTCP -sTCP:LISTEN 2>/dev/null \
  | awk 'NR>1 { n = split($9, a, ":"); print a[n], $2 }' \
  | sort -u -k1,1n -k2,2 \
  | while read -r port pid; do
      comm=$(ps -p "$pid" -o comm= 2>/dev/null)
      base=${comm##*/}
      case "$base" in
        node|bun|deno|vite|next-server*) ;;
        *) continue ;;
      esac
      cwd=$(lsof -a -p "$pid" -d cwd -Fn 2>/dev/null | sed -n 's/^n//p' | head -1)
      up=$(ps -p "$pid" -o etime= 2>/dev/null | tr -d ' ')
      case "$cwd" in "$HOME"*) cwd="~${cwd#"$HOME"}" ;; esac
      printf '%-6s %-7s %-9s %s\n' "$port" "$pid" "${up:-?}" "${cwd:-$base}"
    done
