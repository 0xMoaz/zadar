{
  "name": "zadar",
  "version": "0.3.0",
  "description": "Radar for your agent fleet — Claude Code & Codex sessions, dev servers, and git worktrees on one calm terminal scope.",
  "type": "module",
  "license": "MIT",
  "author": "0xMoaz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xMoaz/zadar.git"
  },
  "homepage": "https://github.com/0xMoaz/zadar",
